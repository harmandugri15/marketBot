# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=MarketBot
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ADMIN_PASSWORD=marketbot2025

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL=sqlite:///./marketbot.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/marketbot

# ── Trading Mode ─────────────────────────────────────────────────────────────
# paper   = simulated fills, no API needed
# forward = real signals logged, paper P&L tracked (no real orders)
# live    = real Groww API orders (requires valid credentials below)
TRADING_MODE=paper

# ── Capital & Risk ────────────────────────────────────────────────────────────
CAPITAL=200000.0
RISK_PCT=1.0
MAX_SL_PCT=12.0
MAX_TRADES_PER_DAY=2

# ── Strategy Parameters ───────────────────────────────────────────────────────
VOL_MULT=1.5
EXPANSION_PCT=4.0
RSI_OVERSOLD=30
MIN_QUALITY=85

# ── Groww API (leave blank for paper/forward mode) ────────────────────────────
GROWW_API_KEY=
GROWW_SECRET_KEY=
GROWW_CLIENT_ID=

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
