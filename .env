# ============================================================
# GROWW API CREDENTIALS
# Replace the values below with your actual Groww API details
# ============================================================

GROWW_API_KEY=
GROWW_SECRET_KEY=
GROWW_CLIENT_ID=

# ============================================================
# TRADING SETTINGS
# ============================================================

# Capital you want to deploy for trading (in Rupees)
TRADING_CAPITAL=2000

# How much of your capital to risk per trade (in %)
# Vijay Thakkar recommends 1-2% per trade
RISK_PER_TRADE_PCT=3

# Maximum stop loss allowed per trade (in %)
# Strategy rule: never more than 5%
MAX_STOP_LOSS_PCT=5.0

# Paper trading mode: TRUE = simulate trades only, FALSE = real orders
PAPER_TRADING=TRUE
